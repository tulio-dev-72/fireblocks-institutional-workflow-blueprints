# Supabase (client-safe publishable values)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Fireblocks (server only — never expose to the browser; see docs/FIREBLOCKS.md)
FIREBLOCKS_API_KEY=
# Vercel/production: inline PEM private key (use \n for line breaks)
FIREBLOCKS_PRIVATE_KEY=
# Local development: path to PEM key file — do not set both PRIVATE_KEY and SECRET_KEY_PATH
FIREBLOCKS_SECRET_KEY_PATH=
FIREBLOCKS_BASE_URL=https://sandbox-api.fireblocks.io/v1

# AI Transaction Summary (Vercel AI Gateway)
# On Vercel deploys, the Gateway authenticates automatically via OIDC — no key needed.
# For local dev, create a key at Vercel > AI Gateway > API Keys:
# AI_GATEWAY_API_KEY=
# Optional model override (defaults to anthropic/claude-sonnet-4.6):
# AI_TX_SUMMARY_MODEL=anthropic/claude-sonnet-4.6

# Optional
# NEXT_PUBLIC_DEMO_MODE=false
# FIREBLOCKS_SOURCE_VAULT_ID=0
# FIREBLOCKS_ASSET_USDC=ETH_TEST5

# Webhooks v2 endpoint (register in Fireblocks Console -> Developer Center -> Webhooks v2,
# subscribe to transaction.created / transaction.status.updated / transaction.approval_status.updated):
# https://institutional-workflow-blueprints.vercel.app/api/webhooks/fireblocks
#
# Webhooks v2 validates the Fireblocks-Webhook-Signature (detached JWS) against the
# environment JWKS automatically. Sandbox is used by default; override only if needed:
# FIREBLOCKS_WEBHOOK_JWKS_URL=https://sandbox-keys.fireblocks.io/.well-known/jwks.json
#
# Legacy v1 fallback (Fireblocks-Signature, RSA-SHA512). Optional override of the public key
# for non-sandbox environments:
# FIREBLOCKS_WEBHOOK_PUBLIC_KEY=
# FIREBLOCKS_WEBHOOK_SKIP_VERIFY=false
